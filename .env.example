# Supabase Configuration
# Get these values from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Admin Key (server-side only, never expose to client)
# Keep this secret and never commit to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Generative AI (Gemini)
# Optional: If not set, mission generation will use the library fallback
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Gemini Model Selection
# Optional: Defaults to 'gemini-2.0-flash' if not specified
GEMINI_MODEL=gemini-2.0-flash

# Storage Configuration
# The mission-artifacts bucket must be created manually before deployment:
# Via Supabase CLI: supabase storage create mission-artifacts --public=false
# Via Dashboard: Storage > New bucket > Name: "mission-artifacts" > Private
# See supabase/migrations/20260407000001_storage_bucket_rls.sql for RLS setup
